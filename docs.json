{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SmartAlex Documentation",
  "colors": {
    "primary": "#010033",
    "light": "#22C55E",
    "dark": "#010033"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "essentials/agents",
              "essentials/campaigns",
              "essentials/phone-numbers"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "essentials/call-logs",
              "essentials/callbacks",
              "essentials/contacts"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.smartalex.ai",
          "icon": "gauge"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@smartalex.ai",
          "icon": "headset"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@smartalex.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.smartalex.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/smartalexai",
      "linkedin": "https://linkedin.com/company/smartalex"
    }
  }
}
